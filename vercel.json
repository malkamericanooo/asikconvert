{
  "version": 2,
  "builds": [
    {
      "src": "imunisasi-app/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "imunisasi-app/dist",
        "buildCommand": "npm run build",
        "installCommand": "npm install"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/imunisasi-app/dist/$1"
    }
  ]
}
